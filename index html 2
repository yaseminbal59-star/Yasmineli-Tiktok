];

let posts = JSON.parse(localStorage.getItem('ym_posts')||'null') || [
  {id:'p1',title:'Beşik Tanıtım',caption:'✨ Yasmineli luxury beşik! #luxurybaby #yasmineli',markets:['GB','US'],date:new Date(Date.now()+3600000).toISOString(),status:'scheduled'},
  {id:'p2',title:'Babynest Unboxing',caption:'👶 Softest nest for your little one! #babynest',markets:['US'],date:new Date(Date.now()+86400000).toISOString(),status:'scheduled'},
  {id:'p3',title:'Roseline SS2025',caption:'👗 Roseline spring koleksiyonu! #roseline',markets:['TR','GB'],date:new Date(Date.now()+172800000).toISOString(),status:'draft'},
];

let automations = JSON.parse(localStorage.getItem('ym_autos')||'null') || [
  {id:'a1',name:'Haftalık Gönderi',type:'recurring_post',desc:'Her Pazartesi 14:00 UK+US\'e otomatik gönderi',tags:['🇬🇧 UK','🇺🇸 US'],enabled:true,last:'2 gün önce',next:'5 gün sonra'},
  {id:'a2',name:'Bütçe Optimizasyonu',type:'budget_optimizer',desc:'CTR %3 altına düşünce bütçeyi yüksek performanslı pazara aktar',tags:['🤖 Otomatik'],enabled:true,last:'3 saat önce',next:'Anlık'},
  {id:'a3',name:'Çok Dilli Caption',type:'caption_generator',desc:'AI ile UK/US/DE pazarları için otomatik caption üret',tags:['🤖 AI','24 caption/ay'],enabled:true,last:'Dün',next:'Perşembe'},
];

const AUTO_ICONS = {recurring_post:'📅',budget_optimizer:'📊',performance_alert:'🔔',ab_test:'🎯',caption_generator:'✍️'};
const PAGES = {
  dashboard:['Dashboard','Tüm kampanya ve otomasyon özeti','+ Kampanya'],
  campaigns:['Kampanyalar','TikTok reklam kampanyalarını yönet','+ Yeni Kampanya'],
  scheduler:['Gönderi Zamanlama','Otomatik içerik takvimi','+ Zamanla'],
  automation:['Otomasyon','Tekrarlayan görevleri otomatikleştir','▶ Çalıştır'],
  analytics:['Analitik','Detaylı performans verileri','Rapor İndir'],
  audience:['Hedef Kitleler','Global pazar segmentleri','+ Segment'],
  integrations:['Entegrasyonlar','Uygulama bağlantıları',''],
  settings:['Ayarlar','Hesap ve bildirim tercihleri',''],
};

let currentPage = 'dashboard';
let connected = JSON.parse(localStorage.getItem('ym_connected')||'false');

function save(){
  localStorage.setItem('ym_campaigns',JSON.stringify(campaigns));
  localStorage.setItem('ym_posts',JSON.stringify(posts));
  localStorage.setItem('ym_autos',JSON.stringify(automations));
  localStorage.setItem('ym_connected',JSON.stringify(connected));
}

// ─── NAVIGATION ───────────────────────────────────────────────────────────────

function go(id){
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(n=>n.classList.remove('active'));
  document.querySelectorAll('.bn-item').forEach(n=>n.classList.remove('active'));
  
  const pg = document.getElementById('page-'+id);
  if(pg) pg.classList.add('active');
  
  document.querySelectorAll('.nav-item').forEach(n=>{
    if(n.getAttribute('onclick')&&n.getAttribute('onclick').includes("'"+id+"'"))
      n.classList.add('active');
  });
  
  const bnEl = document.getElementById('bn-'+id);
  if(bnEl) bnEl.classList.add('active');
  
  const pg2=PAGES[id]||[id,'',''];
  document.getElementById('pg-title').textContent=pg2[0];
  document.getElementById('pg-sub').textContent=pg2[1];
  const tab=document.getElementById('top-action-btn');
  tab.textContent=pg2[2];
  tab.style.display=pg2[2]?'':'none';
  currentPage=id;
  render();
}

function topAction(){
  const map={campaigns:'camp',scheduler:'post-modal',automation:'auto'};
  if(map[currentPage]==='post-modal'){schedulePost();return;}
  if(map[currentPage])openModal(map[currentPage]);
  if(currentPage==='analytics')toast('Rapor oluşturuluyor...','info');
}

// ─── RENDER ───────────────────────────────────────────────────────────────────

function render(){
  const p=currentPage;
  if(p==='dashboard')renderDashboard();
  if(p==='campaigns')renderCampaigns();
  if(p==='scheduler')renderScheduler();
  if(p==='automation')renderAutomation();
  if(p==='analytics')renderAnalytics();
  if(p==='audience')renderAudience();
  if(p==='integrations')renderIntegrations();
  updateHeader();
}

function updateHeader(){
  const btn=document.getElementById('tt-connect-btn');
  const dot=document.getElementById('status-dot');
  if(connected){
    btn.className='tt-btn connected';btn.textContent='♪ @yasmineli__ ✓';
    dot.className='status-dot';
  } else {
    btn.className='tt-btn';btn.textContent='♪ TikTok Bağla';
    dot.className='status-dot off';
  }
}

function renderDashboard(){
  // Market rows
  const mr=document.getElementById('market-rows');
  mr.innerHTML=Object.entries(MARKETS).slice(0,4).map(([k,m])=>`
    <div style="display:flex;align-items:center;gap:10px;padding:9px 0;border-bottom:1px solid rgba(30,30,46,.5)">
      <span style="font-size:20px">${m.flag}</span>
      <div style="flex:1"><div style="font-size:12.5px;font-weight:600">${m.name}</div>
        <div style="font-size:10px;color:var(--muted)">${(m.impressions/1000).toFixed(0)}K görüntülenme · ${m.ctr}% CTR</div></div>
      <div style="flex:1"><div class="prog"><div class="prog-fill" style="width:${Math.min(m.ctr*14,100)}%"></div></div></div>
      <div style="font-family:var(--mono);font-size:12px;font-weight:700;min-width:48px;text-align:right">₺${(m.spend/1000).toFixed(1)}K</div>
    </div>`).join('');

  // Dashboard camps
  const dc=document.getElementById('dash-camps');
  dc.innerHTML=campaigns.filter(c=>c.status==='active').slice(0,3).map(c=>`
    <div class="item"><div class="item-flag">${c.markets.map(m=>MARKETS[m]?.flag||m).join('')}</div>
      <div class="item-info"><div class="item-name">${c.name}</div><div class="item-sub">₺${c.spend.toLocaleString('tr-TR')} harcandı</div></div>
      <span class="badge ${c.status}"><span class="badge-dot"></span>${statusLabel(c.status)}</span></div>`).join('');

  // Upcoming posts
  const up=document.getElementById('dash-posts');
  const now=Date.now();
  const upcoming=posts.filter(p=>new Date(p.date).getTime()>now).slice(0,3);
  up.innerHTML=upcoming.length?upcoming.map(p=>`
    <div class="item">
      <div class="item-info"><div class="item-name">${p.title}</div>
        <div class="item-sub">${formatDate(p.date)} · ${p.markets.map(m=>MARKETS[m]?.flag||m).join('')}</div></div>
      <span class="badge ${p.status}"><span class="badge-dot"></span>${statusLabel(p.status)}</span></div>`).join('')
    :'<div style="color:var(--muted);font-size:12px;text-align:center;padding:15px">Planlanmış gönderi yok</div>';
}

function renderCampaigns(filter='all'){
  const counts={all:campaigns.length,active:campaigns.filter(c=>c.status==='active').length,paused:campaigns.filter(c=>c.status==='paused').length};
  ['all','active','paused'].forEach(k=>{const el=document.getElementById('fc-'+k);if(el)el.textContent=counts[k];});
  document.getElementById('camp-badge').textContent=counts.active;

  const list=filter==='all'?campaigns:campaigns.filter(c=>c.status===filter);
  const t=document.getElementById('camp-table');
  t.innerHTML=`<thead><tr>${['Kampanya','Pazarlar','Bütçe/Gün','Harcama','Görüntülenme','CTR','Dönüşüm','Durum','İşlem'].map(h=>`<th>${h}</th>`).join('')}</tr></thead>
  <tbody>${list.length?list.map(c=>`<tr>
    <td><div class="cn">${c.name}</div><div class="cs">${c.type} · ${c.obj}</div></td>
    <td style="font-size:18px">${c.markets.map(m=>MARKETS[m]?.flag||m).join('')}</td>
    <td style="font-family:var(--mono)">₺${c.budget}</td>
    <td style="font-family:var(--mono)">₺${c.spend.toLocaleString('tr-TR')}</td>
    <td style="font-family:var(--mono)">${(c.impressions/1000).toFixed(0)}K</td>
    <td style="font-family:var(--mono);color:${c.ctr>=4?'var(--success)':c.ctr>=2.5?'var(--warn)':'var(--tt)'}">${c.ctr}%</td>
    <td style="font-family:var(--mono)">${c.conversions}</td>
    <td><span class="badge ${c.status}"><span class="badge-dot"></span>${statusLabel(c.status)}</span></td>
    <td><div style="display:flex;gap:5px">
      <div class="ibtn" onclick="toggleCamp('${c.id}')" title="${c.status==='active'?'Duraklat':'Aktif Et'}">${c.status==='active'?'⏸':'▶️'}</div>
      <div class="ibtn" onclick="delCamp('${c.id}')" title="Sil">🗑</div>
    </div></td></tr>`).join(''):`<tr><td colspan="9" style="text-align:center;padding:30px;color:var(--muted)">Kampanya bulunamadı</td></tr>`}</tbody>`;
}

function renderScheduler(){
  const pl=document.getElementById('posts-list');
  pl.innerHTML=posts.sort((a,b)=>new Date(a.date)-new Date(b.date)).map(p=>`
    <div class="item" style="margin-bottom:8px;flex-direction:column;align-items:flex-start">
      <div style="display:flex;align-items:center;gap:8px;width:100%">
        <div style="flex:1"><div class="item-name">${p.title}</div>
          <div class="item-sub">${p.caption.slice(0,50)}...</div>
          <div class="item-sub">${formatDate(p.date)} · ${p.markets.map(m=>MARKETS[m]?.flag||m).join('')}</div></div>
        <div style="display:flex;gap:5px;align-items:center">
          <span class="badge ${p.status}"><span class="badge-dot"></span>${statusLabel(p.status)}</span>
          <div class="ibtn" onclick="delPost('${p.id}')">🗑</div>
        </div>
      </div>
    </div>`).join('') || '<div style="color:var(--muted);font-size:12px;text-align:center;padding:20px">Henüz gönderi yok</div>';
}

function renderAutomation(){
  const al=document.getElementById('auto-list');
  al.innerHTML=automations.map(a=>`
    <div class="auto-card">
      <div class="auto-icon">${AUTO_ICONS[a.type]||'⚙️'}</div>
      <div class="auto-info">
        <div class="auto-name">${a.name}</div>
        <div class="auto-desc">${a.desc}</div>
        <div class="auto-tags">${a.tags.map(t=>`<span class="auto-tag" style="background:rgba(254,44,85,.1);color:var(--tt)">${t}</span>`).join('')}
          ${a.last?`<span class="auto-tag" style="background:var(--surface);color:var(--muted)">Son: ${a.last}</span>`:''}
        </div>
      </div>
      <div style="display:flex;gap:7px;align-items:center;flex-shrink:0">
        <span class="badge ${a.enabled?'active':'paused'}"><span class="badge-dot"></span>${a.enabled?'Aktif':'Durdu'}</span>
        <button class="btn btn-s" style="font-size:11px" onclick="toggleAuto('${a.id}')">${a.enabled?'⏸ Durdur':'▶ Başlat'}</button>
      </div>
    </div>`).join('');

  const tmpl=document.getElementById('auto-templates');
  tmpl.innerHTML=[
    {icon:'🔄',t:'Tekrarlayan',d:'Belirlenen aralıklarla otomatik içerik yayınla',c:'var(--tt)',type:'recurring_post'},
    {icon:'🔔',t:'Performans Alarmı',d:'CTR veya bütçe eşiği aşıldığında bildirim al',c:'var(--tt2)',type:'performance_alert'},
    {icon:'🎯',t:'A/B Test',d:'İki reklam versiyonunu karşılaştır, kazananı seç',c:'var(--success)',type:'ab_test'},
  ].map(t=>`<div class="panel" style="cursor:pointer;transition:all .2s" 
    onmouseover="this.style.borderColor='${t.c}44'" onmouseout="this.style.borderColor='var(--border)'"
    onclick="document.getElementById('m-auto-type').value='${t.type}';openModal('auto')">
    <div style="font-size:22px;margin-bottom:7px">${t.icon}</div>
    <div style="font-size:12.5px;font-weight:600;margin-bottom:4px">${t.t}</div>
    <div style="font-size:11px;color:var(--muted)">${t.d}</div>
    <div style="margin-top:10px;font-size:11px;color:${t.c};font-weight:600">+ Ekle →</div>
  </div>`).join('');
}

function renderAnalytics(){
  const sp=document.getElementById('sparkline');
  const vals=[45,62,38,78,92,65,100];
  sp.innerHTML=vals.map(v=>`<div class="spark-bar" style="height:${v}%"></div>`).join('');

  const cb=document.getElementById('ctr-bars');
  cb.innerHTML=Object.entries(MARKETS).map(([k,m])=>`
    <div style="margin-bottom:11px">
      <div style="display:flex;justify-content:space-between;font-size:12px;margin-bottom:4px">
        <span>${m.flag} ${m.name}</span>
        <span style="font-family:var(--mono);color:${m.ctr>=5?'var(--success)':m.ctr>=3?'var(--warn)':'var(--tt)'}">${m.ctr}%</span>
      </div>
      <div class="prog"><div class="prog-fill" style="width:${Math.min(m.ctr*14,100)}%"></div></div>
    </div>`).join('');
}

function renderAudience(){
  const ac=document.getElementById('aud-countries');
  const aud=[
    {code:'US',size:'2.4M',reach:92},{code:'GB',size:'1.8M',reach:78},
    {code:'TR',size:'1.1M',reach:62},{code:'DE',size:'900K',reach:45},
    {code:'FR',size:'720K',reach:38},{code:'AU',size:'420K',reach:22},
  ];
  ac.innerHTML=aud.map(a=>`
    <div class="item">
      <div class="item-flag">${MARKETS[a.code]?.flag||a.code}</div>
      <div class="item-info"><div class="item-name">${MARKETS[a.code]?.name||a.code}</div>
        <div class="item-sub">${a.size} potansiyel erişim</div></div>
      <div style="width:70px"><div class="prog"><div class="prog-fill" style="width:${a.reach}%"></div></div></div>
      <div style="font-family:var(--mono);font-size:11px;font-weight:700;color:var(--tt);min-width:30px;text-align:right">%${a.reach}</div>
    </div>`).join('');
}

function renderIntegrations(){
  const il=document.getElementById('int-list');
  const ints=[
    {icon:'♪',name:'TikTok Business API',desc:'Reklam yönetimi ve kampanya oluşturma · @yasmineli__',on:connected},
    {icon:'📊',name:'TikTok Ads Manager',desc:'Tam reklam kampanyası yönetimi ve optimizasyon',on:connected},
    {icon:'💬',name:'WhatsApp Business',desc:'Reklam dönüşümlerini WhatsApp\'a yönlendir',on:true},
    {icon:'📸',name:'Instagram (Meta)',desc:'Instagram ile çapraz gönderi ve Meta Ads entegrasyonu',on:false},
    {icon:'🛒',name:'TikTok Shop',desc:'Ürün kataloğu ve doğrudan satış entegrasyonu',on:false},
  ];
  il.innerHTML=ints.map(i=>`
    <div class="int-card">
      <div class="int-logo">${i.icon}</div>
      <div class="int-info"><div class="int-name">${i.name}</div><div class="int-desc">${i.desc}</div></div>
      ${i.on
        ?'<button class="int-status int-on">✓ Bağlandı</button>'
        :`<button class="int-status int-off" onclick="connectInt('${i.name}')">+ Bağla</button>`}
    </div>`).join('');
}

// ─── ACTIONS ──────────────────────────────────────────────────────────────────

function filterCamps(f){renderCampaigns(f)}

function toggleCamp(id){
  const c=campaigns.find(x=>x.id===id);
  if(!c)return;
  c.status=c.status==='active'?'paused':'active';
  save();renderCampaigns();
  toast(c.status==='active'?'Kampanya aktif edildi ✓':'Kampanya duraklatıldı','success');
}

function delCamp(id){
  if(!confirm('Kampanya silinsin mi?'))return;
  campaigns=campaigns.filter(c=>c.id!==id);
  save();renderCampaigns();toast('Kampanya silindi','info');
}

function saveCampaign(){
  const name=document.getElementById('m-camp-name').value.trim();
  const budget=parseInt(document.getElementById('m-camp-budget').value);
  if(!name){toast('Kampanya adı zorunlu!','error');return;}
  if(!budget||budget<1){toast('Bütçe zorunlu!','error');return;}
  const markets=[...document.querySelectorAll('#m-camp-markets .chip.on')].map(c=>c.getAttribute('onclick').match(/'m-([A-Z]+)'/)?.[1]).filter(Boolean);
  campaigns.push({
    id:'c'+Date.now(),name,type:document.getElementById('m-camp-type').value,
    obj:document.getElementById('m-camp-obj').value,
    markets:markets.length?markets:['GB'],
    budget,spend:0,impressions:0,clicks:0,conversions:0,ctr:0,
    status:'scheduled',date:document.getElementById('m-camp-date').value||new Date().toISOString().split('T')[0]
  });
  save();document.getElementById('modal-camp').classList.remove('open');
  renderCampaigns();toast('Kampanya oluşturuldu! 🚀','success');
}

function schedulePost(){
  const title=document.getElementById('post-title').value.trim();
  const caption=document.getElementById('post-caption').value.trim();
  const date=document.getElementById('post-date').value;
  if(!title||!caption||!date){toast('Tüm alanlar zorunlu!','error');return;}
  const markets=[...document.querySelectorAll('#page-scheduler .chip.on')].map(c=>{
    const m=c.getAttribute('onclick').match(/'([A-Z]+)'/);return m?m[1]:null;
  }).filter(Boolean);
  posts.push({id:'p'+Date.now(),title,caption,markets:markets.length?markets:['GB'],
    date:new Date(date).toISOString(),status:'scheduled'});
  save();
  document.getElementById('post-title').value='';
  document.getElementById('post-caption').value='';
  document.getElementById('post-date').value='';
  renderScheduler();toast('Gönderi zamanlandı! 📅','success');
}

function delPost(id){
  posts=posts.filter(p=>p.id!==id);save();renderScheduler();toast('Gönderi silindi','info');
}

function saveAuto(){
  const name=document.getElementById('m-auto-name').value.trim();
  if(!name){toast('İsim zorunlu!','error');return;}
  automations.push({
    id:'a'+Date.now(),name,type:document.getElementById('m-auto-type').value,
    desc:document.getElementById('m-auto-freq').value+' aralıklarla çalışır',
    tags:[document.getElementById('m-auto-freq').value],enabled:true,last:'Henüz çalışmadı'
  });
  save();document.getElementById('modal-auto').classList.remove('open');
  renderAutomation();toast('Otomasyon oluşturuldu! ⚡','success');
}

function toggleAuto(id){
  const a=automations.find(x=>x.id===id);if(!a)return;
  a.enabled=!a.enabled;save();renderAutomation();
  toast(a.enabled?'Otomasyon aktif edildi ✓':'Otomasyon durduruldu','success');
}

function runAll(){
  toast('Tüm otomasyonlar çalıştırılıyor... ⚡','info');
  setTimeout(()=>toast('3 otomasyon tamamlandı ✓','success'),2000);
}

function connectTikTok(){
  if(connected)return;
  connected=true;save();updateHeader();renderIntegrations();
  toast('TikTok bağlandı! @yasmineli__ ✓','success');
}

function connectInt(name){
  toast(`${name} bağlantısı için TikTok Business hesabı gerekli`,'info');
}

function genCaptions(){
  const product=document.getElementById('cap-product').value;
  const tone=document.getElementById('cap-tone').value;
  const markets=[...document.querySelectorAll('#page-automation .chip.on')].map(c=>{
    const m=c.getAttribute('onclick').match(/'([A-Z]+-cap)'/);return m?m[1].replace('-cap',''):null;
  }).filter(Boolean);
  
  const toneMap={luxury:'lüks ve şık',playful:'eğlenceli ve sevimli',informative:'bilgilendirici'};
  const captions={
    GB:`✨ Introducing ${product} — where luxury meets your little one's world. Premium quality, timeless design. Shop now! #LuxuryBaby #YasmineliUK #NurseryGoals #BabyBoutique`,
    US:`💕 Your baby deserves the best! ${product} is finally here 🎉 Crafted with love for your precious one. Link in bio! #NewbornStyle #YasmineliUS #BabyRegistry #MomLife`,
    TR:`✨ ${product} ile bebeğinize en iyisini sunun! Lüks tasarım, üstün kalite 👶 Hemen sipariş verin! #Yasmineli #LüksBeşik #BebkOdası #AnneVeBebek`,
    DE:`✨ ${product} — Luxus für Ihr kleines Wunder. Handgefertigt mit Liebe und höchster Qualität. Jetzt entdecken! #LuxusBaby #YasmineliDE #Babyzimmer`,
  };
  
  const results=document.getElementById('caption-results');
  const selectedMarkets=markets.length?markets:['GB','US','TR'];
  results.innerHTML=selectedMarkets.filter(m=>captions[m]).map(m=>`
    <div style="margin-bottom:10px;padding:11px;background:var(--surface);border-radius:9px;border:1px solid var(--border)">
      <div style="font-size:10px;font-weight:600;color:var(--muted);margin-bottom:6px">${MARKETS[m]?.flag} ${MARKETS[m]?.name} · ${toneMap[tone]}</div>
      <div style="font-size:12.5px;line-height:1.6">${captions[m]}</div>
      <button class="btn btn-s" style="margin-top:8px;font-size:10px" onclick="copyText(\`${captions[m].replace(/`/g,"'")}\`)">📋 Kopyala</button>
    </div>`).join('');
  toast('Captionlar üretildi! ✓','success');
}

function copyText(t){
  navigator.clipboard.writeText(t).then(()=>toast('Kopyalandı! 📋','success')).catch(()=>toast('Kopyalanamadı','error'));
}

// ─── HELPERS ──────────────────────────────────────────────────────────────────

function statusLabel(s){return{active:'Aktif',paused:'Duraklatıldı',scheduled:'Planlandı',draft:'Taslak',published:'Yayınlandı',ended:'Bitti'}[s]||s}

function formatDate(d){
  try{return new Date(d).toLocaleString('tr-TR',{day:'numeric',month:'short',hour:'2-digit',minute:'2-digit'});}
  catch{return d;}
}

function toggleChip(el,key){el.classList.toggle('on')}

function openModal(id){document.getElementById('modal-'+id).classList.add('open')}
function closeModal(e,id){if(e.target===e.currentTarget)document.getElementById('modal-'+id).classList.remove('open')}

let toastTimer;
function toast(msg,type='success'){
  const t=document.getElementById('toast');
  const colors={success:'var(--success)',error:'var(--tt)',info:'var(--tt2)'};
  const icons={success:'✓',error:'✕',info:'ℹ'};
  t.innerHTML=`<span style="color:${colors[type]};font-size:15px">${icons[type]}</span>${msg}`;
  t.style.borderLeft=`3px solid ${colors[type]}`;
  t.classList.add('show');
  clearTimeout(toastTimer);
  toastTimer=setTimeout(()=>t.classList.remove('show'),3500);
}

// ─── INIT ─────────────────────────────────────────────────────────────────────
updateHeader();render();

// Check due posts every minute
setInterval(()=>{
  const now=Date.now();
  let changed=false;
  posts.forEach(p=>{
    if(p.status==='scheduled'&&new Date(p.date).getTime()<=now){
      p.status='published';changed=true;
      toast(`"${p.title}" yayınlandı! 🎉`,'success');
    }
  });
  if(changed){save();if(currentPage==='scheduler')renderScheduler();}
},60000);
</script>
