<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>Yasmineli · TikTok Manager</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
<style>
:root {
  --bg:#0a0a0f; --surface:#111118; --card:#16161f; --border:#1e1e2e;
  --tt:#fe2c55; --tt2:#25f4ee; --success:#00e5a0; --warn:#ffb547;
  --text:#f0f0f8; --muted:#6b6b8a;
  --font:'DM Sans',system-ui,sans-serif; --mono:'Space Mono',monospace;
}
*{margin:0;padding:0;box-sizing:border-box}
html,body{height:100%;overflow:hidden}
body{background:var(--bg);color:var(--text);font-family:var(--font);display:flex}

/* BG */
body::before{content:'';position:fixed;top:-40%;left:-10%;width:50%;height:90%;
  background:radial-gradient(ellipse,rgba(254,44,85,.07) 0%,transparent 70%);
  pointer-events:none;z-index:0;animation:bp 8s ease-in-out infinite}
body::after{content:'';position:fixed;bottom:-20%;right:-10%;width:50%;height:80%;
  background:radial-gradient(ellipse,rgba(37,244,238,.05) 0%,transparent 70%);
  pointer-events:none;z-index:0;animation:bp 10s ease-in-out infinite reverse}
@keyframes bp{0%,100%{opacity:.6}50%{opacity:1}}

/* SIDEBAR */
#sidebar{width:220px;min-width:220px;background:var(--surface);border-right:1px solid var(--border);
  display:flex;flex-direction:column;height:100vh;position:relative;z-index:10;overflow-y:auto}
.logo{padding:18px 16px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:10px}
.logo-icon{width:34px;height:34px;background:linear-gradient(135deg,var(--tt),var(--tt2));
  border-radius:9px;display:flex;align-items:center;justify-content:center;font-size:17px;
  box-shadow:0 0 18px rgba(254,44,85,.4);flex-shrink:0}
.logo-name{font-size:14px;font-weight:700}.logo-sub{font-size:10px;color:var(--muted);font-family:var(--mono)}
.nav{padding:12px 10px;flex:1}
.nav-sec{font-size:9px;color:var(--muted);font-family:var(--mono);text-transform:uppercase;
  letter-spacing:1px;padding:8px 8px 3px}
.nav-item{display:flex;align-items:center;gap:9px;padding:8px 10px;border-radius:9px;
  font-size:13px;font-weight:500;cursor:pointer;color:var(--muted);transition:all .2s;margin-bottom:1px}
.nav-item:hover{background:var(--card);color:var(--text)}
.nav-item.active{background:rgba(254,44,85,.12);color:var(--tt)}
.nav-item .ni{font-size:15px;width:18px;text-align:center}
.nav-badge{margin-left:auto;background:var(--tt);color:#fff;font-size:9px;font-weight:700;
  padding:1px 5px;border-radius:20px}
.nav-badge.teal{background:var(--tt2);color:#000}
.sidebar-foot{padding:14px;border-top:1px solid var(--border)}
.tt-btn{width:100%;background:linear-gradient(135deg,var(--tt),#ff6b35);border:none;
  border-radius:9px;color:#fff;font-size:12px;font-weight:600;padding:9px;
  cursor:pointer;display:flex;align-items:center;gap:7px;justify-content:center;
  box-shadow:0 4px 18px rgba(254,44,85,.35);transition:all .2s;font-family:var(--font)}
.tt-btn:hover{transform:translateY(-1px);box-shadow:0 6px 22px rgba(254,44,85,.5)}
.tt-btn.connected{background:rgba(0,229,160,.1);border:1px solid rgba(0,229,160,.3);
  color:var(--success);box-shadow:none;cursor:default}
.tt-btn.connected:hover{transform:none}

/* MAIN */
#main{flex:1;display:flex;flex-direction:column;height:100vh;overflow:hidden;position:relative;z-index:1}
.topbar{padding:18px 24px;display:flex;align-items:center;justify-content:space-between;
  border-bottom:1px solid var(--border);flex-shrink:0}
.topbar h1{font-size:20px;font-weight:700}
.topbar p{font-size:12px;color:var(--muted);margin-top:1px}
.topbar-r{display:flex;align-items:center;gap:10px}
.acc-pill{display:flex;align-items:center;gap:7px;background:var(--card);
  border:1px solid var(--border);border-radius:40px;padding:5px 12px 5px 7px;font-size:12px}
.acc-av{width:26px;height:26px;background:linear-gradient(135deg,var(--tt),var(--tt2));
  border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700}
.status-dot{width:6px;height:6px;border-radius:50%;background:var(--success);
  box-shadow:0 0 5px var(--success)}
.status-dot.off{background:var(--warn);box-shadow:0 0 5px var(--warn)}

/* CONTENT */
#content{flex:1;overflow-y:auto;padding:20px 24px}
#content::-webkit-scrollbar{width:4px}
#content::-webkit-scrollbar-thumb{background:var(--border);border-radius:2px}

/* PAGES */
.page{display:none;animation:fadeUp .3s ease}
.page.active{display:block}
@keyframes fadeUp{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:none}}

/* ALERT BAR */
.alert-bar{background:rgba(37,244,238,.08);border:1px solid rgba(37,244,238,.2);
  border-radius:10px;padding:11px 14px;display:flex;align-items:center;gap:9px;
  font-size:12.5px;margin-bottom:18px}
.alert-bar.warn{background:rgba(254,44,85,.08);border-color:rgba(254,44,85,.2)}

/* STATS GRID */
.stats{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:18px}
.stat{background:var(--card);border:1px solid var(--border);border-radius:14px;
  padding:17px;transition:all .25s;cursor:default;position:relative;overflow:hidden}
.stat:hover{border-color:rgba(254,44,85,.3);transform:translateY(-2px)}
.stat:hover::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;
  background:linear-gradient(90deg,var(--tt),var(--tt2))}
.stat-lbl{font-size:11px;color:var(--muted);font-weight:500;margin-bottom:7px}
.stat-val{font-size:24px;font-weight:700;font-family:var(--mono);letter-spacing:-1px}
.stat-chg{font-size:11px;color:var(--success);margin-top:3px}

/* PANELS */
.panel{background:var(--card);border:1px solid var(--border);border-radius:14px;padding:18px}
.panel-title{font-size:13.5px;font-weight:600;margin-bottom:14px;display:flex;align-items:center;gap:7px}
.two-col{display:grid;grid-template-columns:1.4fr 1fr;gap:14px;margin-bottom:18px}
.three-col{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-bottom:18px}

/* BUTTONS */
.btn{padding:7px 14px;border-radius:7px;font-size:12px;font-weight:600;
  cursor:pointer;border:none;transition:all .2s;font-family:var(--font)}
.btn-p{background:linear-gradient(135deg,var(--tt),#d41f45);color:#fff;
  box-shadow:0 3px 10px rgba(254,44,85,.35)}
.btn-p:hover{transform:translateY(-1px);box-shadow:0 5px 16px rgba(254,44,85,.5)}
.btn-s{background:var(--card);color:var(--text);border:1px solid var(--border)}
.btn-s:hover{border-color:var(--tt);color:var(--tt)}
.sh{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px}

/* TABLE */
.tbl{width:100%;border-collapse:collapse}
.tbl th{font-size:10px;font-weight:600;color:var(--muted);text-transform:uppercase;
  letter-spacing:.5px;padding:7px 10px;text-align:left;border-bottom:1px solid var(--border)}
.tbl td{padding:11px 10px;font-size:12.5px;border-bottom:1px solid rgba(30,30,46,.5);vertical-align:middle}
.tbl tr:last-child td{border-bottom:none}
.tbl tr:hover td{background:rgba(254,44,85,.025)}
.cn{font-weight:600;font-size:12.5px}.cs{font-size:10px;color:var(--muted);margin-top:1px}

/* BADGES */
.badge{display:inline-flex;align-items:center;gap:4px;font-size:10px;font-weight:600;
  padding:2px 7px;border-radius:5px}
.badge.active{background:rgba(0,229,160,.12);color:var(--success)}
.badge.paused{background:rgba(255,181,71,.12);color:var(--warn)}
.badge.scheduled{background:rgba(37,244,238,.1);color:var(--tt2)}
.badge.draft{background:rgba(255,181,71,.12);color:var(--warn)}
.badge.published{background:rgba(0,229,160,.12);color:var(--success)}
.badge-dot{width:4px;height:4px;border-radius:50%;background:currentColor}

/* PROGRESS */
.prog{height:5px;background:var(--border);border-radius:3px;overflow:hidden}
.prog-fill{height:100%;border-radius:3px;background:linear-gradient(90deg,var(--tt),#ff6b35);transition:width .5s}
.prog-fill.teal{background:linear-gradient(90deg,var(--tt2),#00c4c0)}

/* ITEMS */
.item{display:flex;align-items:center;gap:11px;padding:10px 11px;
  background:var(--surface);border-radius:9px;border:1px solid var(--border);margin-bottom:7px}
.item:last-child{margin-bottom:0}
.item-flag{font-size:20px;flex-shrink:0}
.item-info{flex:1;min-width:0}
.item-name{font-size:12.5px;font-weight:600}
.item-sub{font-size:10.5px;color:var(--muted);margin-top:1px}

/* SPARKLINE */
.spark{display:flex;align-items:flex-end;gap:3px;height:60px}
.spark-bar{flex:1;border-radius:2px 2px 0 0;background:linear-gradient(0deg,var(--tt),#ff6b35);
  opacity:.7;transition:opacity .2s;cursor:default}
.spark-bar:hover{opacity:1}
.spark-labels{display:flex;justify-content:space-between;font-size:9px;
  color:var(--muted);font-family:var(--mono);margin-top:5px}

/* FORM */
.fg{margin-bottom:13px}
.flbl{font-size:10px;font-weight:600;color:var(--muted);display:block;
  margin-bottom:4px;text-transform:uppercase;letter-spacing:.4px}
.finp{width:100%;background:var(--surface);border:1px solid var(--border);
  border-radius:7px;color:var(--text);font-family:var(--font);font-size:13px;
  padding:8px 11px;outline:none;transition:border-color .2s}
.finp:focus{border-color:var(--tt)}
select.finp{appearance:none;cursor:pointer}
textarea.finp{resize:vertical;min-height:70px}

/* MARKET CHIPS */
.chips{display:flex;gap:5px;flex-wrap:wrap}
.chip{padding:4px 9px;border-radius:7px;font-size:11px;cursor:pointer;
  border:1px solid var(--border);background:var(--surface);color:var(--muted);
  display:flex;align-items:center;gap:4px;transition:all .2s}
.chip.on{background:rgba(254,44,85,.12);border-color:var(--tt);color:var(--tt)}

/* MODAL */
.overlay{position:fixed;inset:0;background:rgba(0,0,0,.75);z-index:1000;
  display:flex;align-items:center;justify-content:center;backdrop-filter:blur(8px);
  opacity:0;pointer-events:none;transition:opacity .3s}
.overlay.open{opacity:1;pointer-events:all}
.modal{background:var(--card);border:1px solid var(--border);border-radius:18px;
  padding:24px;width:440px;max-width:92vw;max-height:85vh;overflow-y:auto;
  transform:scale(.95) translateY(10px);transition:transform .3s}
.overlay.open .modal{transform:scale(1) translateY(0)}
.modal-title{font-size:17px;font-weight:700;margin-bottom:3px}
.modal-sub{font-size:12px;color:var(--muted);margin-bottom:18px}
.modal-foot{display:flex;gap:7px;justify-content:flex-end;margin-top:18px}

/* ICON BTNS */
.ibtn{width:26px;height:26px;background:var(--surface);border:1px solid var(--border);
  border-radius:6px;display:flex;align-items:center;justify-content:center;
  font-size:11px;cursor:pointer;transition:all .2s}
.ibtn:hover{border-color:var(--tt);color:var(--tt)}

/* TOAST */
#toast{position:fixed;bottom:20px;right:20px;z-index:9999;
  background:var(--card);border-radius:10px;padding:11px 16px;
  font-size:12.5px;display:flex;align-items:center;gap:8px;
  box-shadow:0 4px 20px rgba(0,0,0,.5);
  transform:translateY(60px);opacity:0;transition:all .3s;pointer-events:none}
#toast.show{transform:translateY(0);opacity:1}

/* AUTO CARDS */
.auto-card{display:flex;align-items:center;gap:14px;padding:15px;
  background:var(--card);border:1px solid var(--border);border-radius:12px;
  margin-bottom:10px;transition:all .2s}
.auto-card:hover{border-color:rgba(254,44,85,.25)}
.auto-icon{font-size:26px;flex-shrink:0}
.auto-info{flex:1}
.auto-name{font-size:13px;font-weight:600}
.auto-desc{font-size:11px;color:var(--muted);margin-top:3px}
.auto-tags{display:flex;gap:6px;margin-top:6px;flex-wrap:wrap}
.auto-tag{font-size:10px;padding:2px 7px;border-radius:4px;font-weight:500}

/* INTEGRATION */
.int-card{display:flex;align-items:center;gap:12px;padding:14px;
  background:var(--surface);border:1px solid var(--border);border-radius:11px;
  margin-bottom:8px;transition:all .2s}
.int-card:hover{border-color:rgba(254,44,85,.25)}
.int-logo{font-size:26px;flex-shrink:0}
.int-info{flex:1}
.int-name{font-size:13px;font-weight:600}
.int-desc{font-size:11px;color:var(--muted)}
.int-status{font-size:11px;padding:3px 9px;border-radius:5px;font-weight:600;cursor:pointer;border:none;font-family:var(--font)}
.int-on{background:rgba(0,229,160,.12);color:var(--success)}
.int-off{background:rgba(254,44,85,.15);color:var(--tt);cursor:pointer}

/* MOBILE BOTTOM NAV */
@media(max-width:700px){
  #sidebar{display:none!important}
  #main{width:100%!important}
  #bottom-nav{display:flex!important}
  #content{padding:14px 12px!important;padding-bottom:80px!important}
  .stats{grid-template-columns:repeat(2,1fr)!important}
  .two-col,.three-col{grid-template-columns:1fr!important}
  .topbar{padding:12px 14px!important}
  .topbar h1{font-size:17px!important}
  .topbar-r .acc-pill span{display:none}
  #top-action-btn{font-size:11px!important;padding:6px 10px!important}
}
@media(min-width:701px){#bottom-nav{display:none!important}}

#bottom-nav{
  position:fixed;bottom:0;left:0;right:0;
  background:var(--surface);
  border-top:1px solid var(--border);
  z-index:200;
  justify-content:space-around;
  padding:8px 0 10px;
  display:none;
}
.bn-item{
  display:flex;flex-direction:column;align-items:center;gap:2px;
  font-size:9px;color:var(--muted);cursor:pointer;padding:4px 8px;
  border-radius:8px;transition:all .2s;font-weight:500;
  -webkit-tap-highlight-color:transparent;
  user-select:none;
  min-width:50px;
}
.bn-item.active{color:var(--tt)}
.bn-item .bni{font-size:20px}
</style>
</head>
<body>

<!-- SIDEBAR (Desktop) -->
<nav id="sidebar">
  <div class="logo">
    <div class="logo-icon">♪</div>
    <div><div class="logo-name">Yasmineli</div><div class="logo-sub">TikTok Manager</div></div>
  </div>
  <div class="nav">
    <div class="nav-sec">Yönetim</div>
    <div class="nav-item active" onclick="go('dashboard')"><span class="ni">📊</span>Dashboard</div>
    <div class="nav-item" onclick="go('campaigns')"><span class="ni">📣</span>Kampanyalar<span class="nav-badge" id="camp-badge">4</span></div>
    <div class="nav-item" onclick="go('scheduler')"><span class="ni">🗓</span>Zamanlama</div>
    <div class="nav-item" onclick="go('automation')"><span class="ni">⚡</span>Otomasyon<span class="nav-badge teal">AI</span></div>
    <div class="nav-sec">Analitik</div>
    <div class="nav-item" onclick="go('analytics')"><span class="ni">📈</span>Performans</div>
    <div class="nav-item" onclick="go('audience')"><span class="ni">🌍</span>Hedef Kitleler</div>
    <div class="nav-sec">Hesap</div>
    <div class="nav-item" onclick="go('integrations')"><span class="ni">🔗</span>Entegrasyonlar</div>
    <div class="nav-item" onclick="go('settings')"><span class="ni">⚙️</span>Ayarlar</div>
  </div>
  <div class="sidebar-foot">
    <button class="tt-btn connected" id="tt-connect-btn" onclick="connectTikTok()">♪ @yasmineli__ ✓</button>
  </div>
</nav>

<!-- MAIN -->
<div id="main">
  <div class="topbar">
    <div><h1 id="pg-title">Dashboard</h1><p id="pg-sub">Tüm kampanya ve otomasyon özeti</p></div>
    <div class="topbar-r">
      <div class="acc-pill">
        <div class="acc-av">Y</div>
        <span>@yasmineli__</span>
        <div class="status-dot" id="status-dot"></div>
      </div>
      <button class="btn btn-p" id="top-action-btn" onclick="topAction()">+ Kampanya</button>
    </div>
  </div>

  <div id="content">

    <!-- ═══ DASHBOARD ═══════════════════════════════════════════════ -->
    <div class="page active" id="page-dashboard">
      <div class="alert-bar">
        <span>⚡</span>
        <span>3 otomasyon aktif · <strong style="color:var(--tt2)">Bugün 14:00'da</strong> beşik tanıtım videosu yayınlanacak · UK kitlesi optimize edildi</span>
      </div>
      <div class="stats">
        <div class="stat"><div class="stat-lbl">💰 Toplam Harcama</div><div class="stat-val" style="color:var(--tt)">₺18.4K</div><div class="stat-chg">↑ %23 bu ay</div></div>
        <div class="stat"><div class="stat-lbl">👁 Görüntülenme</div><div class="stat-val" style="color:var(--tt2)">2.8M</div><div class="stat-chg">↑ %41</div></div>
        <div class="stat"><div class="stat-lbl">🖱 CTR Oranı</div><div class="stat-val">4.7%</div><div class="stat-chg">↑ 0.8pp</div></div>
        <div class="stat"><div class="stat-lbl">🛒 Dönüşüm</div><div class="stat-val" style="color:var(--success)">312</div><div class="stat-chg">↑ %18</div></div>
      </div>
      <div class="two-col">
        <div class="panel">
          <div class="panel-title">🌍 Pazar Performansı</div>
          <div id="market-rows"></div>
        </div>
        <div>
          <div class="panel" style="margin-bottom:14px">
            <div class="sh"><div class="panel-title" style="margin:0">📣 Aktif Kampanyalar</div><button class="btn btn-s" style="font-size:11px" onclick="go('campaigns')">Tümü</button></div>
            <div id="dash-camps"></div>
          </div>
          <div class="panel">
            <div class="sh"><div class="panel-title" style="margin:0">⏰ Yaklaşan</div><button class="btn btn-s" style="font-size:11px" onclick="go('scheduler')">Takvim</button></div>
            <div id="dash-posts"></div>
          </div>
        </div>
      </div>
    </div>

    <!-- ═══ CAMPAIGNS ════════════════════════════════════════════════ -->
    <div class="page" id="page-campaigns">
      <div class="sh">
        <div style="display:flex;gap:6px;flex-wrap:wrap">
          <button class="btn btn-s" style="font-size:11px" onclick="filterCamps('all')">Tümü (<span id="fc-all">0</span>)</button>
          <button class="btn btn-s" style="font-size:11px;color:var(--success);border-color:var(--success)" onclick="filterCamps('active')">Aktif (<span id="fc-active">0</span>)</button>
          <button class="btn btn-s" style="font-size:11px;color:var(--warn);border-color:var(--warn)" onclick="filterCamps('paused')">Duraklatıldı (<span id="fc-paused">0</span>)</button>
        </div>
        <button class="btn btn-p" onclick="openModal('camp')">+ Yeni Kampanya</button>
      </div>
      <div class="panel" style="overflow-x:auto">
        <table class="tbl" id="camp-table"></table>
      </div>
    </div>

    <!-- ═══ SCHEDULER ════════════════════════════════════════════════ -->
    <div class="page" id="page-scheduler">
      <div class="two-col">
        <div>
          <div class="panel" style="margin-bottom:14px">
            <div class="panel-title">✏️ Yeni Gönderi Oluştur</div>
            <div class="fg"><label class="flbl">Başlık</label><input class="finp" id="post-title" placeholder="Beşik Tanıtım..."></div>
            <div class="fg"><label class="flbl">Caption / Açıklama</label><textarea class="finp" id="post-caption" placeholder="#yasmineli #luxurybaby..."></textarea></div>
            <div class="fg"><label class="flbl">Pazarlar</label>
              <div class="chips">
                <div class="chip on" onclick="toggleChip(this,'GB')">🇬🇧 UK</div>
                <div class="chip on" onclick="toggleChip(this,'US')">🇺🇸 US</div>
                <div class="chip" onclick="toggleChip(this,'TR')">🇹🇷 TR</div>
                <div class="chip" onclick="toggleChip(this,'DE')">🇩🇪 DE</div>
                <div class="chip" onclick="toggleChip(this,'ALL')">🌍 Tümü</div>
              </div>
            </div>
            <div class="fg"><label class="flbl">Yayın Tarihi & Saati</label><input class="finp" id="post-date" type="datetime-local"></div>
            <button class="btn btn-p" style="width:100%" onclick="schedulePost()">📅 Zamanla</button>
          </div>
          <div class="panel">
            <div class="panel-title">⏰ En İyi Gönderim Saatleri</div>
